  "questions": [
    {"id":"algo-p2-01","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Check whether a list is sorted","prompt":"Arrange the lines to report whether the values are in ascending order.","explanation":"Assume the list is sorted, compare each value with the one before it, and change the flag when an inversion appears.","variants":{"python":{"lines":["nums = [2, 4, 7, 6]","sorted_ok = True","for i in range(1, len(nums)):","    if nums[i] < nums[i - 1]:","        sorted_ok = False","print(sorted_ok)"]},"java":{"lines":["int[] nums = {2, 4, 7, 6};","boolean sortedOk = true;","for (int i = 1; i < nums.length; i++) {","    if (nums[i] < nums[i - 1]) {","        sortedOk = false;","    }","}","System.out.println(sortedOk);"]},"javascript":{"lines":["const nums = [2, 4, 7, 6];","let sortedOk = true;","for (let i = 1; i < nums.length; i++) {","  if (nums[i] < nums[i - 1]) {","    sortedOk = false;","  }","}","console.log(sortedOk);"]},"cpp":{"lines":["int nums[] = {2, 4, 7, 6};","bool sortedOk = true;","for (int i = 1; i < 4; i++) {","    if (nums[i] < nums[i - 1]) {","        sortedOk = false;","    }","}","cout << boolalpha << sortedOk;"]}}},
    {"id":"algo-p2-02","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Create running totals","prompt":"Arrange the lines to create and print a running-total collection.","explanation":"Maintain one total across the loop. After adding each value, append the new total so every position records the sum so far.","variants":{"python":{"lines":["nums = [2, 3, 5]","running = []","total = 0","for n in nums:","    total += n","    running.append(total)","print(running)"]},"java":{"lines":["int[] nums = {2, 3, 5};","int[] running = new int[nums.length];","int total = 0;","for (int i = 0; i < nums.length; i++) {","    total += nums[i];","    running[i] = total;","}","System.out.println(Arrays.toString(running));"]},"javascript":{"lines":["const nums = [2, 3, 5];","const running = [];","let total = 0;","for (const n of nums) {","  total += n;","  running.push(total);","}","console.log(running);"]},"cpp":{"lines":["vector<int> nums = {2, 3, 5};","vector<int> running;","int total = 0;","for (int n : nums) {","    total += n;","    running.push_back(total);","}","for (int n : running) cout << n << ' '; "]}}},
    {"id":"algo-p2-03","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Count a target in a matrix","prompt":"Arrange the lines to count how many times 1 appears in a two-dimensional collection.","explanation":"The outer loop visits rows and the inner loop visits each value in that row. Increment only when the current value matches the target.","variants":{"python":{"lines":["grid = [[1, 0], [1, 1]]","count = 0","for row in grid:","    for value in row:","        if value == 1:","            count += 1","print(count)"]},"java":{"lines":["int[][] grid = {{1, 0}, {1, 1}};","int count = 0;","for (int[] row : grid) {","    for (int value : row) {","        if (value == 1) count++;","    }","}","System.out.println(count);"]},"javascript":{"lines":["const grid = [[1, 0], [1, 1]];","let count = 0;","for (const row of grid) {","  for (const value of row) {","    if (value === 1) count++;","  }","}","console.log(count);"]},"cpp":{"lines":["int grid[2][2] = {{1, 0}, {1, 1}};","int count = 0;","for (auto& row : grid) {","    for (int value : row) {","        if (value == 1) count++;","    }","}","cout << count;"]}}},
    {"id":"algo-p2-04","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Find the second largest distinct value","prompt":"Arrange the lines to track the largest and second-largest distinct values.","explanation":"When a new maximum arrives, move the old maximum into second place first. Otherwise update second only for a distinct value between the two.","variants":{"python":{"lines":["nums = [5, 9, 3, 7]","largest = float('-inf')","second = float('-inf')","for n in nums:","    if n > largest:","        second, largest = largest, n","    elif largest > n > second:","        second = n","print(second)"]},"java":{"lines":["int[] nums = {5, 9, 3, 7};","int largest = Integer.MIN_VALUE, second = Integer.MIN_VALUE;","for (int n : nums) {","    if (n > largest) {","        second = largest; largest = n;","    } else if (n < largest && n > second) {","        second = n;","    }","}","System.out.println(second);"]},"javascript":{"lines":["const nums = [5, 9, 3, 7];","let largest = -Infinity, second = -Infinity;","for (const n of nums) {","  if (n > largest) {","    second = largest; largest = n;","  } else if (n < largest && n > second) {","    second = n;","  }","}","console.log(second);"]},"cpp":{"lines":["int nums[] = {5, 9, 3, 7};","int largest = INT_MIN, second = INT_MIN;","for (int n : nums) {","    if (n > largest) {","        second = largest; largest = n;","    } else if (n < largest && n > second) {","        second = n;","    }","}","cout << second;"]}}},
    {"id":"algo-p2-05","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Keep first occurrences","prompt":"Arrange the lines to build a list with duplicates removed while preserving order.","explanation":"Scan from left to right and append only values not already present. This preserves the first occurrence of each value.","variants":{"python":{"lines":["nums = [3, 1, 3, 2, 1]","unique = []","for n in nums:","    if n not in unique:","        unique.append(n)","print(unique)"]},"java":{"lines":["int[] nums = {3, 1, 3, 2, 1};","List<Integer> unique = new ArrayList<>();","for (int n : nums) {","    if (!unique.contains(n)) {","        unique.add(n);","    }","}","System.out.println(unique);"]},"javascript":{"lines":["const nums = [3, 1, 3, 2, 1];","const unique = [];","for (const n of nums) {","  if (!unique.includes(n)) {","    unique.push(n);","  }","}","console.log(unique);"]},"cpp":{"lines":["vector<int> nums = {3, 1, 3, 2, 1};","vector<int> unique;","for (int n : nums) {","    if (find(unique.begin(), unique.end(), n) == unique.end()) {","        unique.push_back(n);","    }","}","for (int n : unique) cout << n << ' '; "]}}},
    {"id":"algo-p2-06","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Check a palindrome","prompt":"Arrange the lines to report whether the text reads the same forward and backward.","explanation":"Compare mirrored positions from the two ends. Any mismatch changes the flag; only half the string needs to be checked.","variants":{"python":{"lines":["text = 'level'","is_palindrome = True","for i in range(len(text) // 2):","    if text[i] != text[-i - 1]:","        is_palindrome = False","print(is_palindrome)"]},"java":{"lines":["String text = \"level\";","boolean isPalindrome = true;","for (int i = 0; i < text.length() / 2; i++) {","    if (text.charAt(i) != text.charAt(text.length() - i - 1)) {","        isPalindrome = false;","    }","}","System.out.println(isPalindrome);"]},"javascript":{"lines":["const text = \"level\";","let isPalindrome = true;","for (let i = 0; i < Math.floor(text.length / 2); i++) {","  if (text[i] !== text[text.length - i - 1]) {","    isPalindrome = false;","  }","}","console.log(isPalindrome);"]},"cpp":{"lines":["string text = \"level\";","bool isPalindrome = true;","for (int i = 0; i < text.size() / 2; i++) {","    if (text[i] != text[text.size() - i - 1]) {","        isPalindrome = false;","    }","}","cout << boolalpha << isPalindrome;"]}}},
    {"id":"algo-p2-07","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Find the best row total","prompt":"Arrange the lines to find the largest row sum in a matrix.","explanation":"Reset the row total for each row, sum that row in the inner loop, and compare the completed row total with the best value.","variants":{"python":{"lines":["grid = [[2, 4], [7, 1]]","best = 0","for row in grid:","    row_total = 0","    for value in row:","        row_total += value","    if row_total > best:","        best = row_total","print(best)"]},"java":{"lines":["int[][] grid = {{2, 4}, {7, 1}};","int best = 0;","for (int[] row : grid) {","    int rowTotal = 0;","    for (int value : row) rowTotal += value;","    if (rowTotal > best) best = rowTotal;","}","System.out.println(best);"]},"javascript":{"lines":["const grid = [[2, 4], [7, 1]];","let best = 0;","for (const row of grid) {","  let rowTotal = 0;","  for (const value of row) rowTotal += value;","  if (rowTotal > best) best = rowTotal;","}","console.log(best);"]},"cpp":{"lines":["int grid[2][2] = {{2, 4}, {7, 1}};","int best = 0;","for (auto& row : grid) {","    int rowTotal = 0;","    for (int value : row) rowTotal += value;","    if (rowTotal > best) best = rowTotal;","}","cout << best;"]}}},
    {"id":"algo-p2-08","concept":"algorithm-problems-2","difficulty":"medium","kind":"parsons","title":"Move zeros to the end","prompt":"Arrange the lines to collect nonzero values first, then append the required zeros.","explanation":"Keep nonzero values in their original order and count zeros separately. Append that many zeros after the scan.","variants":{"python":{"lines":["nums = [0, 3, 0, 2]","result = []","zeros = 0","for n in nums:","    if n == 0: zeros += 1","    else: result.append(n)","result.extend([0] * zeros)","print(result)"]},"java":{"lines":["int[] nums = {0, 3, 0, 2};","List<Integer> result = new ArrayList<>();","int zeros = 0;","for (int n : nums) {","    if (n == 0) zeros++; else result.add(n);","}","for (int i = 0; i < zeros; i++) result.add(0);","System.out.println(result);"]},"javascript":{"lines":["const nums = [0, 3, 0, 2];","const result = [];","let zeros = 0;","for (const n of nums) {","  if (n === 0) zeros++; else result.push(n);","}","for (let i = 0; i < zeros; i++) result.push(0);","console.log(result);"]},"cpp":{"lines":["vector<int> nums = {0, 3, 0, 2};","vector<int> result;","int zeros = 0;","for (int n : nums) {","    if (n == 0) zeros++; else result.push_back(n);","}","for (int i = 0; i < zeros; i++) result.push_back(0);","for (int n : result) cout << n << ' '; "]}}}
